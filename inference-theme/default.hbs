<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,500&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{asset "css/main.css"}}">
    {{ghost_head}}
</head>
<body class="{{body_class}}">

<header class="topbar">
    <div class="shell topbar-inner">
        <a href="{{@site.url}}" class="logo">
            <span class="br">[&nbsp;]</span>
            <span>INFERENCE</span>
        </a>
        <nav class="nav" aria-label="primary">
            <a href="{{@site.url}}" class="{{#is "home"}}active{{/is}}">
                <span class="prompt">~&gt;</span><span>home</span>
            </a>
            <a href="{{@site.url}}tag/ai-ml/" class="{{#is "tag"}}active{{/is}}">
                <span class="prompt">~&gt;</span><span>archive</span>
            </a>
            <a href="{{@site.url}}about/">
                <span class="prompt">~&gt;</span><span>about</span>
            </a>
        </nav>
        <div class="tools">
            {{> "language-switcher"}}
            <button class="icon-btn theme-toggle" aria-label="toggle theme" title="toggle theme">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                    <circle cx="12" cy="12" r="4"/>
                    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
                </svg>
            </button>
        </div>
    </div>
</header>

{{{body}}}

<footer class="shell pagefoot">
    <div class="brand">
        <a href="{{@site.url}}" class="logo">
            <span class="br">[&nbsp;]</span>
            <span>INFERENCE</span>
        </a>
        <div class="tagline">"{{@site.description}}"</div>
        <div class="copy">© {{date format="YYYY"}} INFERENCE. Single-author publication. No sponsored content.</div>
    </div>
    <div>
        <h5>archive</h5>
        <a href="{{@site.url}}tag/ai-ml/">AI / ML</a>
        <a href="{{@site.url}}tag/architecture/">Architecture</a>
        <a href="{{@site.url}}tag/infrastructure/">Infrastructure</a>
    </div>
    <div>
        <h5>links</h5>
        <a href="{{@site.url}}about/">about</a>
        <a href="{{@site.url}}rss/">RSS / Atom</a>
    </div>
    <div>
        <h5>instance</h5>
        <a href="https://en.yourblog.com">en.inference.dev</a>
        <a href="https://pt.yourblog.com">pt.inference.dev</a>
    </div>
</footer>

<div class="statusbar" role="contentinfo" id="js-statusbar">
    <span class="seg"><span class="ok">●</span><span class="v">200 OK</span></span>
    <span class="seg"><span class="k">env</span><span class="v">production</span></span>
    <span class="seg"><span class="k">page</span><span class="v" id="js-sb-page">/home</span></span>
    <span class="seg"><span class="k">lang</span><span class="v">{{@site.locale}}</span></span>
    <span class="seg"><span class="k">theme</span><span class="v" id="js-sb-theme">dark</span></span>
    <span class="seg right"><span class="k">utc</span><span class="v" id="js-sb-clock">--:--:--</span></span>
    <span class="seg"><span class="k">build</span><span class="v">v0.1.0</span></span>
</div>

<script src="{{asset "js/main.js"}}"></script>
{{ghost_foot}}
</body>
</html>
