{{!< default}}

<main>
    <section class="hero">
        <div class="shell hero-inner">
            <div class="meta">
                <span class="dot"></span>
                <span>LIVE — PUBLISHING NOW</span>
            </div>
            <h1>Rigorous thinking on <em>AI,</em> software and infrastructure.</h1>
            <p class="lede">{{@site.description}}</p>
        </div>
    </section>

    <section class="shell">
        <div class="section-heading">
            <div class="title">recent posts</div>
        </div>
        <div class="post-grid">
            {{#foreach posts}}
            <article class="post-card">
                {{#if feature_image}}
                    <img src="{{img_url feature_image size="m"}}" alt="{{title}}">
                {{/if}}
                <div class="topbits">
                    {{#if primary_tag}}<span class="tag t-{{primary_tag.slug}}">{{primary_tag.name}}</span>{{/if}}
                    <span>{{date format="YYYY — MM — DD"}}</span>
                </div>
                <h3 class="ttl"><a href="{{url}}">{{title}}</a></h3>
                <p class="dek">{{excerpt words="30"}}</p>
                <div class="foot">
                    <span>{{reading_time}}</span>
                    <span style="margin-left:auto" class="arrow">→</span>
                </div>
            </article>
            {{/foreach}}
        </div>
        {{pagination}}
    </section>
</main>
