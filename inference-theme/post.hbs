{{!< default}}

{{#post}}
<main>
    <div class="progress-bar" id="js-progress"></div>

    <section class="shell">
        <div class="post-header">
            <div class="crumbs">
                <a href="{{@site.url}}">~</a>
                <span class="sep">/</span>
                <a href="{{@site.url}}archive/" style="color:var(--fg-dim)">archive</a>
                {{#if primary_tag}}
                <span class="sep">/</span>
                <a href="{{primary_tag.url}}" class="a-tag t-{{primary_tag.slug}}"
                   style="color:var(--accent)">{{primary_tag.name}}</a>
                {{/if}}
            </div>
            <h1>{{title}}</h1>
            {{#if custom_excerpt}}
            <p class="lede">{{custom_excerpt}}</p>
            {{/if}}
            <div class="byline">
                <span>by <span class="name">{{primary_author.name}}</span></span>
                <span class="sep">·</span>
                <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="YYYY — MM — DD"}}</time>
                <span class="sep">·</span>
                <span>{{reading_time}}</span>
            </div>
        </div>

        <div class="post-layout">

            {{! ── Left sidebar: TOC ──────────────────────────────────────── }}
            <aside class="sidebar-l">
                <div class="toc" id="js-toc">
                    <h5>table of contents</h5>
                    <ol id="js-toc-list"></ol>
                </div>
            </aside>

            {{! ── Article body ────────────────────────────────────────────── }}
            <article class="post-body prose">
                {{#unless access}}
                <div class="gh-post-upgrade-cta">
                    <p>This content is for members only.</p>
                    <a href="{{@site.url}}#/portal/">Subscribe to read</a>
                </div>
                {{/unless}}

                {{content}}

                {{#if tags}}
                <footer class="tags">
                    {{#foreach tags}}<a href="{{url}}">#{{name}}</a>{{/foreach}}
                </footer>
                {{/if}}

                <div style="margin-top:64px;padding-top:24px;border-top:1px solid var(--rule);display:flex;justify-content:space-between;gap:16px;font-family:var(--font-mono);font-size:12px;color:var(--fg-mute);">
                    {{#prev_post}}
                    <a href="{{url}}" style="color:var(--fg-dim)">← {{title}}</a>
                    {{/prev_post}}
                    {{#next_post}}
                    <a href="{{url}}" style="color:var(--accent);margin-left:auto">{{title}} →</a>
                    {{/next_post}}
                </div>
            </article>

            {{! ── Right sidebar: post meta ────────────────────────────────── }}
            <aside class="sidebar-r">
                <div class="post-meta-side">
                    <h5>post info</h5>
                    <div class="kv">
                        {{#if primary_tag}}<span class="k">topic</span><span>{{primary_tag.name}}</span>{{/if}}
                        <span class="k">posted</span><span>{{date format="YYYY — MM — DD"}}</span>
                        <span class="k">read</span><span>{{reading_time}}</span>
                        <span class="k">author</span><span>{{primary_author.name}}</span>
                        <span class="k">lang</span><span>{{@site.locale}}</span>
                    </div>

                    <h5>share</h5>
                    <div class="share">
                        <a href="{{url}}">→ copy link</a>
                        <a href="https://twitter.com/intent/tweet?url={{url}}&text={{title}}">→ share on x</a>
                    </div>

                    <h5>version</h5>
                    <div class="kv">
                        <span class="k">en</span><a href="https://en.yourblog.com">en.inference.dev</a>
                        <span class="k">pt</span><a href="https://pt.yourblog.com">pt.inference.dev</a>
                    </div>
                </div>
            </aside>

        </div>
    </section>
</main>
{{/post}}
