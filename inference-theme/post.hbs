{{!< default}}

{{#post}}
<main>
    <section class="shell">
        <div class="post-header">
            <div class="crumbs">
                <a href="{{@site.url}}">~</a>
                <span class="sep">/</span>
                {{#if primary_tag}}
                    <a href="{{primary_tag.url}}" class="a-tag t-{{primary_tag.slug}}">{{primary_tag.name}}</a>
                    <span class="sep">/</span>
                {{/if}}
            </div>
            <h1>{{title}}</h1>
            <p class="lede">{{custom_excerpt}}</p>
            <div class="byline">
                <span>by <span class="name">{{primary_author.name}}</span></span>
                <span class="sep">·</span>
                <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="YYYY — MM — DD"}}</time>
                <span class="sep">·</span>
                <span>{{reading_time}}</span>
            </div>
        </div>

        <div class="post-layout">
            <aside class="sidebar-l">
                <div class="toc" id="js-toc">
                    <h5>table of contents</h5>
                    <ol id="js-toc-list"></ol>
                </div>
            </aside>

            <article class="post-body prose">
                <div class="progress-bar" id="js-progress"></div>
                {{content}}

                {{#if tags}}
                <footer class="tags">
                    {{#foreach tags}}<a href="{{url}}">#{{name}}</a>{{/foreach}}
                </footer>
                {{/if}}
            </article>

            <aside class="sidebar-r">
                <div class="post-meta-side">
                    <h5>post info</h5>
                    <div class="kv">
                        {{#if primary_tag}}<span class="k">topic</span><span>{{primary_tag.name}}</span>{{/if}}
                        <span class="k">posted</span><span>{{date format="YYYY — MM — DD"}}</span>
                        <span class="k">read</span><span>{{reading_time}}</span>
                        <span class="k">lang</span><span>{{@site.locale}}</span>
                    </div>

                    <h5>version</h5>
                    <div class="kv">
                        <span class="k">en</span><a href="https://en.yourblog.com">en.inference.dev</a>
                        <span class="k">pt</span><a href="https://pt.yourblog.com">pt.inference.dev</a>
                    </div>
                </div>
            </aside>
        </div>
    </section>
</main>
{{/post}}
